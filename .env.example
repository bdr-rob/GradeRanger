# --- Supabase (required for signup / login)
# Dashboard → Project Settings → API → Project URL + anon public key (JWT starting with eyJ)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# Authentication → URL Configuration: add http://localhost:8080 (or your dev URL)

# Optional: Python card scanner API (FastAPI)
# VITE_SCANNER_API_URL=http://127.0.0.1:8000
VITE_SCANNER_API_URL=
